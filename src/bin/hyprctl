#!/usr/bin/env python3
import sys
import json
import os
import configparser

def get_friendly_category(section, description):
    if section == "kwin":
        if "Window" in description or "Desktop" in description:
            return "Window"
        return "System"
    elif section == "plasmashell":
        return "Plasma"
    elif "dolphin" in section:
        return "File Manager"
    elif "konsole" in section or "kitty" in section:
        return "Terminal"
    return section.capitalize()

def parse_kglobalshortcutsrc():
    path = os.path.expanduser("~/.config/kglobalshortcutsrc")
    if not os.path.exists(path):
        return []
    
    config = configparser.ConfigParser(interpolation=None)
    config.optionxform = str
    try:
        config.read(path)
    except Exception:
        return []

    mod_map = {
        "Shift": 1,
        "Ctrl": 4,
        "Alt": 8,
        "Meta": 64
    }
    
    binds = []
    
    for section in config.sections():
        for key, value in config.items(section):
            parts = value.split(',')
            if len(parts) >= 3:
                shortcut = parts[0]
                description = parts[2]
                
                if shortcut and shortcut != "none":
                    keys = shortcut.split('+')
                    modmask = 0
                    actual_key = ""
                    for k in keys:
                        if k in mod_map:
                            modmask |= mod_map[k]
                        else:
                            actual_key = k
                    
                    if actual_key:
                        category = get_friendly_category(section, description)
                        binds.append({
                            "description": f"{category}: {description}",
                            "modmask": modmask,
                            "key": actual_key.upper()
                        })
    return binds

def parse_keyd():
    path = "/etc/keyd/quickshell.conf"
    if not os.path.exists(path):
        # Fallback to local quickshell.conf for testing/if not system-wide yet
        fallback = os.path.expanduser("~/.config/quickshell/quickshell.conf")
        if os.path.exists(fallback):
            path = fallback
        else:
            return []
        
    binds = []
    mod_map = {
        "shift": 1,
        "control": 4,
        "alt": 8,
        "meta": 64
    }
    
    try:
        current_modmask = 0
        with open(path, 'r') as f:
            for line in f:
                line = line.strip()
                if not line or line.startswith('#') or line == "[ids]" or line == "*":
                    continue
                if line.startswith('['):
                    sec = line[1:-1].lower()
                    current_modmask = 0
                    if sec == "main":
                        continue
                    for mod in sec.split('+'):
                        if mod in mod_map:
                            current_modmask |= mod_map[mod]
                    continue
                
                if '=' in line:
                    k, v = line.split('=', 1)
                    k = k.strip()
                    v = v.strip()
                    
                    actual_key = k
                    if actual_key == "sysrq":
                        actual_key = "Print"
                    elif actual_key == "playpause":
                        actual_key = "XF86AudioPlay"
                    elif actual_key == "nextsong":
                        actual_key = "XF86AudioNext"
                    elif actual_key == "previoussong":
                        actual_key = "XF86AudioPrev"
                    elif actual_key == "mute":
                        actual_key = "XF86AudioMute"
                    elif actual_key == "micmute":
                        actual_key = "XF86AudioMicMute"
                    elif actual_key == "volumedown":
                        actual_key = "XF86AudioLowerVolume"
                    elif actual_key == "volumeup":
                        actual_key = "XF86AudioRaiseVolume"
                    elif actual_key == "brightnessdown":
                        actual_key = "XF86MonBrightnessDown"
                    elif actual_key == "brightnessup":
                        actual_key = "XF86MonBrightnessUp"
                    else:
                        actual_key = actual_key.capitalize()

                    modmask = current_modmask

                    desc = "Custom shortcut"
                    category = "Keyd"
                    
                    if "zen-browser" in v:
                        category, desc = "App", "Browser"
                    elif "code" in v:
                        category, desc = "App", "Code editor"
                    elif "dolphin" in v:
                        category, desc = "App", "File manager"
                    elif "systemsettings" in v:
                        category, desc = "App", "Settings app"
                    elif "kitty" in v:
                        category, desc = "App", "Terminal"
                    elif "kate" in v:
                        category, desc = "App", "Text editor"
                    elif "wpctl set-mute @DEFAULT_SOURCE@" in v:
                        category, desc = "Media", "Toggle mic"
                    elif "wpctl set-mute @DEFAULT_SINK@" in v:
                        category, desc = "Media", "Toggle mute"
                    elif "playerctl play-pause" in v:
                        category, desc = "Media", "Play/pause media"
                    elif "playerctl next" in v:
                        category, desc = "Media", "Next track"
                    elif "playerctl previous" in v:
                        category, desc = "Media", "Previous track"
                    elif "volume set 0.05 -" in v:
                        category, desc = "Volume", "Down"
                    elif "volume set 0.05 +" in v:
                        category, desc = "Volume", "Up"
                    elif "brightness decrement" in v:
                        category, desc = "Brightness", "Down"
                    elif "brightness increment" in v:
                        category, desc = "Brightness", "Up"
                    elif "loginctl lock-session" in v:
                        category, desc = "Session", "Lock"
                    elif "systemctl poweroff" in v:
                        category, desc = "Session", "Shut down"
                    elif "systemctl suspend" in v:
                        category, desc = "Session", "Sleep"
                    elif "qs -c ii ipc call wallpaperSelector toggle" in v:
                        category, desc = "Shell", "Change wallpaper"
                    elif "qs -c ii ipc call search clipboardToggle" in v:
                        category, desc = "Shell", "View Clipboard"
                    elif "wallpaperSelector random" in v:
                        category, desc = "Shell", "Random wallpaper"
                    elif "panelFamily cycle" in v:
                        category, desc = "Shell", "Cycle panel family"
                    elif "killall ydotool qs quickshell" in v:
                        category, desc = "Shell", "Restart widgets"
                    elif "bar toggle" in v:
                        category, desc = "Shell", "Toggle bar"
                    elif "sidebarLeft toggle" in v:
                        category, desc = "Shell", "Toggle left sidebar"
                    elif "theme toggleLightDark" in v:
                        category, desc = "Shell", "Toggle light/dark mode"
                    elif "mediaControls toggle" in v:
                        category, desc = "Shell", "Toggle media controls"
                    elif "osk toggle" in v:
                        category, desc = "Shell", "Toggle on-screen keyboard"
                    elif "overlay toggle" in v:
                        category, desc = "Shell", "Toggle widget overlay"
                    elif "session toggle" in v:
                        category, desc = "Shell", "Toggle session menu"
                    elif "search toggleRelease" in v:
                        category, desc = "Shell", "Toggle search"
                    elif "search toggle" in v:
                        category, desc = "Shell", "Toggle search"
                    elif "overviewWorkspaces toggle" in v:
                        category, desc = "Shell", "Toggle overview"
                    elif "sidebarRight toggle" in v:
                        category, desc = "Shell", "Toggle right sidebar"
                    elif "cheatsheet toggle" in v:
                        category, desc = "Shell", "Toggle cheatsheet"
                    elif "region ocr" in v:
                        category, desc = "Utilities", "Character recognition >> clipboard"
                    elif "region search" in v:
                        category, desc = "Utilities", "Google Lens"
                    elif "hyprpicker" in v:
                        category, desc = "Utilities", "Pick color #RRGGBB >> clipboard"
                    elif "record.sh --fullscreen --sound" in v:
                        category, desc = "Utilities", "Record screen (with sound)"
                    elif "record.sh --fullscreen" in v:
                        category, desc = "Utilities", "Record region (no sound)"
                    elif "region record" in v:
                        category, desc = "Utilities", "Record region (alt)"
                    elif "grim" in v and "wl-copy" in v:
                        category, desc = "Utilities", "Screenshot >> clipboard"
                    elif "grim" in v and "Screenshot_" in v:
                        category, desc = "Utilities", "Screenshot >> clipboard & file"
                    elif "region screenshot" in v:
                        category, desc = "Utilities", "Screen snip"
                    elif "screenTranslator translate" in v:
                        category, desc = "Utilities", "Translate screen content"
                    elif "cliphist" in v:
                        category, desc = "Utilities", "Clipboard history >> clipboard"
                    elif "libreoffice" in v:
                        category, desc = "App", "Office software"
                    elif "pavucontrol" in v:
                        category, desc = "App", "Volume mixer"
                    elif "plasma-systemmonitor" in v:
                        category, desc = "App", "Task manager"
                    
                    binds.append({
                        "description": f"{category}: {desc}",
                        "modmask": modmask,
                        "key": actual_key
                    })
    except Exception:
        pass
    return binds

if __name__ == "__main__":
    if len(sys.argv) >= 3 and sys.argv[1] == "binds" and sys.argv[2] == "-j":
        binds = parse_keyd() + parse_kglobalshortcutsrc()
        print(json.dumps(binds, indent=2))
    elif len(sys.argv) >= 3 and sys.argv[1] == "monitors" and sys.argv[2] == "-j":
        print("[]")
    elif len(sys.argv) >= 3 and sys.argv[1] == "workspaces" and sys.argv[2] == "-j":
        print("[]")
    elif len(sys.argv) >= 3 and sys.argv[1] == "activeworkspace" and sys.argv[2] == "-j":
        print('{"id": 1}')
    else:
        print("Mock hyprctl (Python KDE+Keyd bridge)")
