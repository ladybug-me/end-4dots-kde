#!/bin/bash
# Mock hyprpicker that uses KDE's DBus color picker

COLOR=$(qdbus6 org.kde.KWin /ColorPicker org.kde.kwin.ColorPicker.pick)
if [[ -n "$COLOR" ]]; then
    # Format #AARRGGBB to #RRGGBB
    # $COLOR comes as an integer representing ARGB
    HEX=$(printf "#%06x" $((COLOR & 0xFFFFFF)))
    echo "$HEX"
    if [[ "$1" == "-a" ]]; then
        echo -n "$HEX" | wl-copy
    fi
fi
